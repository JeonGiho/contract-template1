ill="6" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2848" Protect="false" RowAddr="16" RowSpan="1" Width="24777"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="64"><CHAR>02-123-4567</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="6" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2848" Protect="false" RowAddr="17" RowSpan="1" Width="20331"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="55"><CHAR>보건소</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="6" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2848" Protect="false" RowAddr="17" RowSpan="1" Width="24777"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="64"><CHAR>02-123-4567</CHAR></TEXT></P></PARALIST></CELL></ROW></TABLE><CHAR/></TEXT></P><P ParaShape="6" Style="0"><TEXT CharShape="2"><TABLE BorderFill="6" CellSpacing="0" ColCount="3" PageBreak="Cell" RepeatHeader="true" RowCount="19"><SHAPEOBJECT InstId="2043973749" Lock="false" NumberingType="Table" TextWrap="TopAndBottom" ZOrder="16"><SIZE Height="51509" HeightRelTo="Absolute" Protect="false" Width="50740" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="0" Right="0" Top="0"/></SHAPEOBJECT><INSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/><ROW><CELL BorderFill="90" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="3404" Protect="false" RowAddr="0" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="73" Style="0"><TEXT CharShape="42"><CHAR>간호(조무)사의 급여제공범위</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="91" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="883" Protect="false" RowAddr="1" RowSpan="1" Width="50740"><CELLMARGIN Bottom="0" Left="0" Right="0" Top="0"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="60"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="92" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="2" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>■ 여러분을 정성껏 돌봐드리는 ‘</CHAR></TEXT><TEXT CharShape="6"><CHAR>간호(조무)사’</CHAR></TEXT><TEXT CharShape="5"><CHAR>란?</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="78" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="3" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="46" Style="0"><TEXT CharShape="5"><CHAR>☞ 간호에 대한 체계적인 교육을 이수하고 </CHAR></TEXT><TEXT CharShape="6"><CHAR>국가자격증을 보유한 전문인력</CHAR></TEXT><TEXT CharShape="5"><CHAR>입니다.</CHAR></TEXT></P><P ParaShape="47" Style="0"><TEXT CharShape="5"><CHAR>☞「노인복지법」,「노인장기요양보험법」및 관련법령에 따라 수급자 어르신의 건강과 안녕, 복지증진을 위해 최선의 노력을 다하고 있습니다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="78" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="4" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="78" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="5" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>■</CHAR></TEXT><TEXT CharShape="6"><CHAR>「노인장기요양보험법」및 시행규칙에는 간호(조무)사의 업무범위가 정확하게 명시되어 있습니다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="93" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="6" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>(1)</CHAR></TEXT><TEXT CharShape="6"><CHAR>「노인장기요양보험법」제4장 제23조(장기요양급여의 종류)</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="94" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="7" RowSpan="1" Width="6704"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="5"><CHAR>구분</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="95" ColAddr="1" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="7" RowSpan="1" Width="44036"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="5"><CHAR>내용</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="96" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1666" Protect="false" RowAddr="8" RowSpan="1" Width="6704"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="6"><CHAR>방문요양</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="19" ColAddr="1" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1666" Protect="false" RowAddr="8" RowSpan="1" Width="44036"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>장기요양요원이 수급자의 가정 등을 방문하여 신체활동 및 가사활동 등을 지원.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="97" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1666" Protect="false" RowAddr="9" RowSpan="1" Width="6704"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="6"><CHAR>방문목욕</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="23" ColAddr="1" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1666" Protect="false" RowAddr="9" RowSpan="1" Width="44036"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>장기요양요원이 목욕설비를 갖춘 장비를 이용하여 수급자의 가정 등을 방문하여 목욕을 제공.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="98" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="566" Protect="false" RowAddr="10" RowSpan="1" Width="6704"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="6"><CHAR>방문간호</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="88" ColAddr="1" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="566" Protect="false" RowAddr="10" RowSpan="1" Width="44036"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="45"><CHAR>장기요양요원인 간호사 등이 의사, 한의사 또는 치과의사의 지시서에 따라 수급자의 가정 등을</CHAR></TEXT><TEXT CharShape="5"><CHAR> 방문하여 간호, 진료의 보조, 요양에 관한 상담 또는 구강위생 등을 제공.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="99" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="11" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="18"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="100" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="12" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>(2)</CHAR></TEXT><TEXT CharShape="6"><CHAR>「노인장기요양보험법」제4장 제28조의2(급여외행위의 제공 금지)</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="101" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="13" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="46" Style="0"><TEXT CharShape="45"><CHAR>수급자와 장기요양기관은 장기요양급여를 제공받거나 제공할 경우에는 </CHAR></TEXT><TEXT CharShape="44"><CHAR>다음 각 호의 행위를 요구하거나</CHAR></TEXT><TEXT CharShape="6"><CHAR> 제공하여서는 아니 된다.</CHAR></TEXT></P><P ParaShape="47" Style="0"><TEXT CharShape="6"><CHAR> ① 수급자의 가족을 위한 행위 </CHAR></TEXT><TEXT CharShape="5"><CHAR>(예를 들면 명절음식․제사음식을 준비하거나 김장하기 등)</CHAR></TEXT></P><P ParaShape="47" Style="0"><TEXT CharShape="5"><CHAR> </CHAR></TEXT><TEXT CharShape="6"><CHAR>② 수급자 또는 그 가족의 생업을 지원하는 행위</CHAR></TEXT><TEXT CharShape="5"><CHAR> (농사일, 영업행위 등)</CHAR></TEXT></P><P ParaShape="47" Style="0"><TEXT CharShape="5"><CHAR> </CHAR></TEXT><TEXT CharShape="6"><CHAR>③ 그 밖에 수급자의 일상생활에 지장이 없는 행위</CHAR></TEXT><TEXT CharShape="5"><CHAR> (예를 들면 대형유리창을 닦는 행위 등)</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="78" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="14" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="18"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="93" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="15" RowSpan="1" Width="50740"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="6"><CHAR>■ 구체적인 업무범위 및 예시(방문간호)</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="94" ColAddr="0" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="16" RowSpan="1" Width="14137"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="5"><CHAR>구분</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="95" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="16" RowSpan="1" Width="36603"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="5"><CHAR>내용</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="97" ColAddr="0" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1566" Protect="false" RowAddr="17" RowSpan="1" Width="14137"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="5"><CHAR>건강관리</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="23" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="17" RowSpan="1" Width="36603"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>관절 오그라듦 예방, 투약관리(복약 지도, 약 투여 및 확인, 약 도포 및 약 삽입), 자기주사 교육 및 관리, 기본 건강관리(기초건강사정, 감염 간호, 치매 등 정보 제공), 교육 및 상담(의료기관 의뢰 포함), 인지훈련(인지기능 장애 완화 목적 훈련 제공) 등</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="98" ColAddr="0" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1600" Protect="false" RowAddr="18" RowSpan="1" Width="14137"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="5"><CHAR>간호관리</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="88" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1600" Protect="false" RowAddr="18" RowSpan="1" Width="36603"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="5"><CHAR>욕창관리(욕창 예방 및 간호), 영양관리(튜브영양공급), 비위관(L-tube) 교환, 통증관리, 배설관리(도뇨관 관리, 회음부 간호, 요루 및 장루 간호, 방광 및 배설감지 간호 등), 호흡기기 관리(흡인 간호 등), 기관절개관 및 산소요법 관리, 투석간호와 구강강소(구강 감염 예방 등) 등</CHAR></TEXT></P></PARALIST></CELL></ROW></TABLE><CHAR/></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="35"><TABLE BorderFill="6" CellSpacing="0" ColCount="1" PageBreak="Cell" RepeatHeader="true" RowCount="1"><SHAPEOBJECT InstId="2043973739" Lock="false" NumberingType="Table" TextWrap="TopAndBottom" ZOrder="13"><SIZE Height="70617" HeightRelTo="Absolute" Protect="false" Width="49892" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/></SHAPEOBJECT><INSIDEMARGIN Bottom="141" Left="510" Right="510" Top="141"/><ROW><CELL BorderFill="6" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="70617" Protect="false" RowAddr="0" RowSpan="1" Width="49892"><CELLMARGIN Bottom="141" Left="510"