os="0"><ROTATIONINFO Angle="0" CenterX="1417" CenterY="0" Rotate="1"/><RENDERINGINFO><TRANSMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><SCAMATRIX E1="28.340000" E2="0.000000" E3="0.000000" E4="0.000000" E5="0.010000" E6="0.000000"/><ROTMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/></RENDERINGINFO></SHAPECOMPONENT><LINESHAPE Alpha="0" EndCap="Flat" HeadSize="MediumMedium" HeadStyle="Normal" Style="Solid" TailSize="SmallSmall" TailStyle="Arrow" Width="33"/><SHADOW Alpha="0" Color="11711154" OffsetX="0" OffsetY="0" Type="0"/></DRAWINGOBJECT><CONTROLPOINT Type="3" X="0" Y="0"/><CONTROLPOINT Type="26" X="100" Y="0"/></CONNECTLINE><CHAR/></TEXT></P></PARALIST></CELL><CELL BorderFill="29" ColAddr="16" ColSpan="3" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2081" Protect="false" RowAddr="31" RowSpan="1" Width="11774"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="157"><CHAR>통보</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="54" ColAddr="0" ColSpan="4" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1182" Protect="false" RowAddr="32" RowSpan="1" Width="9279"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="66"><CHAR>요청인</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="54" ColAddr="4" ColSpan="3" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1182" Protect="false" RowAddr="32" RowSpan="1" Width="3988"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="66"/></P></PARALIST></CELL><CELL BorderFill="54" ColAddr="7" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1182" Protect="false" RowAddr="32" RowSpan="1" Width="8360"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="66"><CHAR>경찰서장</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="54" ColAddr="8" ColSpan="2" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1182" Protect="false" RowAddr="32" RowSpan="1" Width="3956"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="66"/></P></PARALIST></CELL><CELL BorderFill="54" ColAddr="10" ColSpan="4" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1182" Protect="false" RowAddr="32" RowSpan="1" Width="8608"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="66"><CHAR>경찰서장</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="54" ColAddr="14" ColSpan="2" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1182" Protect="false" RowAddr="32" RowSpan="1" Width="4733"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="66"/></P></PARALIST></CELL><CELL BorderFill="54" ColAddr="16" ColSpan="3" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1182" Protect="false" RowAddr="32" RowSpan="1" Width="11774"><CELLMARGIN Bottom="141" Left="283" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="99" Style="0"><TEXT CharShape="66"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="113" ColAddr="0" ColSpan="19" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="567" Protect="false" RowAddr="33" RowSpan="1" Width="50698"><CELLMARGIN Bottom="141" Left="141" Right="141" Top="0"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="138" Style="0"><TEXT CharShape="64"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="66" ColAddr="0" ColSpan="19" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2214" Protect="false" RowAddr="34" RowSpan="1" Width="50698"><CELLMARGIN Bottom="141" Left="141" Right="141" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Bottom"><P ParaShape="133" Style="13"><TEXT CharShape="90"><CHAR>210㎜×297㎜[백상지 80g/㎡(재활용품)]</CHAR></TEXT></P></PARALIST></CELL></ROW></TABLE><CHAR/></TEXT></P><P ParaShape="80" Style="0"><TEXT CharShape="69"/></P><P ParaShape="45" Style="0"><TEXT CharShape="41"><CHAR>요양보호사 업무가이드</CHAR></TEXT></P><P ParaShape="45" Style="0"><TEXT CharShape="41"/></P><P ParaShape="83" Style="0"><TEXT CharShape="36"><CHAR>업무범위</CHAR></TEXT></P><P ParaShape="84" Style="0"><TEXT CharShape="36"><CHAR>- 신체활동지원 및 인지활동지원, 정서지원, 가사 및 일상생활지원 </CHAR></TEXT></P><P ParaShape="84" Style="0"><TEXT CharShape="36"><CHAR>- 수급자 급여제공기록지 기록 (수급자상태변화 관칠기록 포함)</CHAR></TEXT></P><P ParaShape="84" Style="0"><TEXT CharShape="36"><CHAR>- 수급자 서비스 제공 계획수립 및 변경에 관한 보고 <LINEBREAK/>- 특별행사 등의 경우 보충적 활동제공</CHAR></TEXT></P><P ParaShape="84" Style="0"><TEXT CharShape="88"/></P><P ParaShape="85" Style="0"><TEXT CharShape="36"><CHAR>2. 기관보고사항</CHAR></TEXT></P><P ParaShape="86" Style="0"><TEXT CharShape="36"><CHAR>①태그오류(시작, 종료 지연전송 및 미전송 등)</CHAR></TEXT></P><P ParaShape="86" Style="0"><TEXT CharShape="36"><CHAR>②일정변경 (수급자, 보호자, 요양보호사에 의한 일정변경, 연장 및 단축도 포함)</CHAR></TEXT></P><P ParaShape="86" Style="0"><TEXT CharShape="36"><CHAR>③일일특이사항(수급자, 보호자의 상태 및 욕구 등)</CHAR></TEXT></P><P ParaShape="86" Style="0"><TEXT CharShape="36"><CHAR>④핸드폰 분실 및 고장, 전화번호 변경</CHAR></TEXT></P><P ParaShape="86" Style="0"><TEXT CharShape="88"/></P><P ParaShape="87" Style="0"><TEXT CharShape="36"><CHAR>3. 태그전송 시 주의사항</CHAR></TEXT></P><P ParaShape="88" Style="0"><TEXT CharShape="36"><CHAR>급여계약통보(계획) 시간을 준수합니다.<LINEBREAK/>⦁ 방문시간과 급여계약통보(계획) 상의 일정과 서비스내용을 확인합니다.<LINEBREAK/>⦁ 급여계약통보(계획)시간 기준, 서비스제공 총시간은 1~2분의 여유를 두고 종료태그를<LINEBREAK/>   전송합니다.<LINEBREAK/>⦁ 급여계약통보(계획)시간 기준, </CHAR></TEXT><TEXT CharShape="97"><CHAR>±</CHAR></TEXT><TEXT CharShape="36"><CHAR>30분 이상 차이 발생시 기관 담당자에게 보고합니다.</CHAR></TEXT></P><P ParaShape="86" Style="0"><TEXT CharShape="88"/></P><P ParaShape="89" Style="0"><TEXT CharShape="36"><CHAR>4. 사회보험 취득 기준</CHAR></TEXT></P><P ParaShape="90" Style="0"><TEXT CharShape="36"><CHAR>- 국민연금 : 월60시간 이상 근로자 (60세 이상, 60시간 미만근로자 제외)</CHAR></TEXT></P><P ParaShape="90" Style="0"><TEXT CharShape="36"><CHAR>- 건강보험 : 월60시간 이상 근로자 (60시간 미만근로자 제외)</CHAR></TEXT></P><P ParaShape="90" Style="0"><TEXT CharShape="36"><CHAR>- 고용보험 : 근무시간 무관 (이중취득 확인 필요)</CHAR></TEXT></P><P ParaShape="90" Style="0"><TEXT CharShape="36"><CHAR>- 산재보험 : 근무시간 무관</CHAR></TEXT></P><P ParaShape="90" Style="0"><TEXT CharShape="88"/></P><P ParaShape="91" Style="0"><TEXT CharShape="36"><CHAR>5. 업무주의사항<LINEBREAK/>- 근로기준법에 의거하여 4시간 이상 근로시 30분의 휴게시간을 부여합니다.(시급산정 제외)<LINEBREAK/>- 수급자의 상태 및 환경을 고려하여 안전사고가 일어나거나 사생활 침해가 발생하지 않도록<LINEBREAK/>  합니다.<LINEBREAK/>- 수급자에게 응급상황 또는 조치가 필요한 상황이 발생하면 임의로 판단하지 않고<LINEBREAK/>  즉시 관리자에게 보고합니다.<LINEBREAK/>- 수급자나 가족이 부당한 요구를 할 경우, 즉시 거절하고 관련 대응지침을 따릅니다.<LINEBREAK/>- 급여를 제공할 때는 항상 단정하고 위생적인 복장을 착용합니다.<LINEBREAK/>- 매년 건강검진을 받고, 평소 계획적인 휴식과 운동, 건강관리를 통해 근골격계질환이나<LINEBREAK/>  감염을 예방하기 위해 노력합니다.<LINEBREAK/>- 수급자에 대한 학대나 기관의 부당행위를 발견하였을 경우는 지체 없이 관련 절차에<LINEBREAK/>  따라 신고합니다.<LINEBREAK/>- 서비스 제공시 급여제공계획에 따르되, 욕구를 고려하여 필요한 서비스를 차례로 제공합니다.<LINEBREAK/>- 제공한 급여내용을 매일 기록하며, 특히 신체기능, 식사기능, 인지기능, 배변상황 등<LINEBREAK/>  변화상태를 관찰하여 기록합니다. (급여제공기록지 또는 태그 특이사항)<LINEBREAK/>- 급여제공을 마무리하기 전에 수급자나 가족에게 더 필요한 것이 있는지 확인합니다.<LINEBREAK/>  (가스, 전기, 수도, 문단속 등 안전 확인을 실시)<LINEBREAK/>- 장기요양급여제공기록지(태그)를 최종적으로 정리·작성하고 수급자 또는 가족에게 설명한 후<LINEBREAK/>  날인을 받습니다.<LINEBREAK/></CHAR></TEXT></P><P ParaShape="91" Style="0"><TEXT CharShape="36"/></P><P ParaShape="91" Style="0"><TEXT CharShape="36"/></P><P ParaShape="91" Style="0"><TEXT CharShape="36"/></P><P ParaShape="91" Style="0"><TEXT CharShape="36"/></P><P ParaShape="35" Style="0"><TEXT CharShape="33"><CHAR>수급자 급여제공계획서 교육자료</CHAR></TEXT></P><P ParaShape="49" Style="0"><TEXT CharShape="34"/></P><P ParaShape="49" Style="0"><TEXT CharShape="34"><CHAR>1. 수급자 정보</CHAR></TEXT></P><P ParaShape="49" Style="0"><TEXT CharShape="35"><TABLE BorderFill="3" CellSpacing="0" ColCount="6" PageBreak="Cell" RepeatHeader="true" RowCount="1"><SHAPEOBJECT InstId="2014295988" Lock="false" NumberingType="Table" TextWrap="TopAndBottom" ZOrder="16"><SIZE Height="3142" HeightRelTo="Absolute" Protect="false" Width="50826" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Column" TreatAsChar="false" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/></SHAPEOBJECT><INSIDEMARGIN Bottom="141" Left="510" Right="510" Top="141"/><ROW><CELL BorderFill="3" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="3142" Protect="false" RowAddr="0" RowSpan="1" Width="8471"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="35" Style="0"><TEXT CharShape="34"><CHAR>성함</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="3142" Pr