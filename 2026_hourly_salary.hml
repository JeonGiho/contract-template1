원본 그림의 크기: 가로 238pixel, 세로 105pixel</SHAPECOMMENT></SHAPEOBJECT><SHAPECOMPONENT GroupLevel="0" HorzFlip="false" InstID="990349033" OriHeight="1740" OriWidth="3947" VertFlip="false" XPos="0" YPos="0"><ROTATIONINFO Angle="0" CenterX="1973" CenterY="870" Rotate="1"/><RENDERINGINFO><TRANSMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><SCAMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><ROTMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><SCAMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><ROTMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><SCAMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><ROTMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><SCAMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/><ROTMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/></RENDERINGINFO></SHAPECOMPONENT><IMAGERECT X0="0" X1="3947" X2="3947" X3="0" Y0="0" Y1="0" Y2="1740" Y3="1740"/><IMAGECLIP Bottom="7860" Left="0" Right="17880" Top="0"/><INSIDEMARGIN Bottom="0" Left="0" Right="0" Top="0"/><IMAGEDIM Height="7860" Width="17880"/><IMAGE Alpha="0" BinItem="2" Bright="0" Contrast="0" Effect="RealPic"/><EFFECTS/></PICTURE><CHAR>서명)</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="167" ColAddr="2" ColSpan="4" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1783" Protect="false" RowAddr="24" RowSpan="1" Width="13049"><CELLMARGIN Bottom="0" Left="0" Right="0" Top="0"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="206" Style="0"><TEXT CharShape="191"><CHAR>전 요 보</CHAR></TEXT><TEXT CharShape="196"><CHAR>  (</CHAR><PIC