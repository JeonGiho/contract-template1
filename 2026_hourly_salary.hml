n="0" VertAlign="Center"><P ParaShape="127" Style="0"><TEXT CharShape="91"><CHAR>   </CHAR></TEXT><TEXT CharShape="93"><CHAR>본인은 「장애인복지법」 제59조의3제4항 본문, 제5항 본문 및 같은 법 시행령 제36조의2제1항에 따른 장애인학대</CHAR></TEXT><TEXT CharShape="68"><CHAR>관련범죄 및 성범죄에 대한 경력 조회에 동의합니다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="70" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4598" Protect="false" RowAddr="6" RowSpan="1" Width="48186"><CELLMARGIN Bottom="141" Left="141" Right="141" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="62" Style="0"><TEXT CharShape="79"><CHAR>#{근로계약일}</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="70" ColAddr="0" ColSpan="2" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4598" Protect="false" RowAddr="7" RowSpan="1" Width="27738"><CELLMARGIN Bottom="141" Left="141" Right="141" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="82" Style="26"><TEXT CharShape="31"><CHAR>동의자</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="70" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4598" Protect="false" RowAddr="7" RowSpan="1" Width="20448"><CELLMARGIN Bottom="141" Left="141" Right="141" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="131" Style="26"><TEXT CharShape="31"><CHAR> </CHAR></TEXT><TEXT CharShape="55"><CHAR>#{시설장명} </CHAR></TEXT><TEXT CharShape="31"><CHAR>(서명 또는 날인)</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="70" ColAddr="0" ColSpan="3" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="5245" Protect="false" RowAddr="8" RowSpan="1" Width="48186"><CELLMARGIN Bottom="141" Left="141" Right="141" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" L