" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="40"><CHAR>(인)</CHAR></TEXT></P></PARALIST></CELL></ROW></TABLE><CHAR/></TEXT></P><P ParaShape="96" Style="0"><TEXT CharShape="40"><CHAR>  </CHAR></TEXT><TEXT CharShape="65"/></P></PARALIST></CELL></ROW></TABLE><CHAR/></TEXT></P><P ParaShape="36" Style="0"><TEXT CharShape="86"><CHAR>계약내용 확인서</CHAR></TEXT></P><P ParaShape="34" Style="0"><TEXT CharShape="7"/></P><P ParaShape="109" Style="0"><TEXT CharShape="4"><TABLE BorderFill="6" CellSpacing="0" ColCount="4" PageBreak="Cell" RepeatHeader="true" RowCount="3"><SHAPEOBJECT InstId="2033298618" Lock="false" NumberingType="Table" TextFlow="BothSides" TextWrap="Square" ZOrder="87"><SIZE Height="4674" HeightRelTo="Absolute" Protect="false" Width="48372" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="2138" HorzRelTo="Column" TreatAsChar="false" VertAlign="Top" VertOffset="718" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/></SHAPEOBJECT><INSIDEMARGIN Bottom="141" Left="510" Right="510" Top="141"/><ROW><CELL BorderFill="213" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2337" Protect="false" RowAddr="0" RowSpan="1" Width="12093"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="20" Style="0"><TEXT CharShape="4"><CHAR>안내일자</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="214" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2337" Protect="false" RowAddr="0" RowSpan="1" Width="12093"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertA