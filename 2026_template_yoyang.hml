 E2="0.000000" E3="2471.000000" E4="0.000000" E5="1.662530" E6="-1033.000000"/><ROTMATRIX E1="1.000000" E2="0.000000" E3="0.000000" E4="0.000000" E5="1.000000" E6="0.000000"/></RENDERINGINFO></SHAPECOMPONENT><IMAGERECT X0="0" X1="10531" X2="10531" X3="0" Y0="0" Y1="0" Y2="3953" Y3="3953"/><IMAGECLIP Bottom="7500" Left="0" Right="19980" Top="0"/><INSIDEMARGIN Bottom="0" Left="0" Right="0" Top="0"/><IMAGEDIM Height="7500" Width="19980"/><IMAGE Alpha="0" BinItem="13" Bright="0" Contrast="0" Effect="RealPic"/><EFFECTS/></PICTURE><CHAR/></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="118" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="9" RowSpan="1" Width="50174"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="8"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="108" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="0" Protect="false" RowAddr="10" RowSpan="1" Width="50174"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="80"><CHAR>■ 탈수증상 발생 시 대처방법</CHAR></TEXT></P><P ParaShape="57" Style="0"><TEXT CharShape="2"><CHAR>① 탈수라고 생각될 경우 물 또는 스포츠음료를 충분히 마시고 휴식을 취합니다.</CHAR></TEXT></P><P ParaShape="57" Style="0"><TEXT CharShape="2"><CHAR>② 어지럼증 등이 심할 경우 담당 요양보호사에게 이야기하고, 필요한 경우 병원치료를 받도록 합니다.</CHAR></TEXT></P></PARALIST></CELL></ROW></TABLE><CHAR/></TEXT></P><P ParaShape="36" Style="0"><TEXT CharShape="37"/></P><P ParaShape="36" Style="0"><TEXT CharShape="37"/></P><P ParaShape="36" Style="0"><TEXT CharShape="37"/></P><P ParaShape="18" Style="0"><TEXT CharShape="37"><TABLE BorderFill="6" CellSpacing="0" ColCount="2" PageBreak="Cell" RepeatHeader="true" RowCount="17"><SHAPEOBJECT InstId="1102627124" Lock="false" NumberingType="Table" TextWrap="TopAndBottom" ZOrder="45"><SIZE Height="72768" HeightRelTo="Absolute" Protect="false" Width="50174" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Para" TreatAsChar="true" VertAlign="Top" VertOffset="0" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="0" Left="0" Right="0" Top="0"/></SHAPEOBJECT><INSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/><ROW><CELL BorderFill="90" ColAddr="0" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="3404" Protect="false" RowAddr="0" RowSpan="1" Width="50174"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="18" Style="0"><TEXT CharShape="43"><CHAR>배변도움</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="119" ColAddr="0" ColSpan="2" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="883" Protect="false" RowAddr="1" RowSpan="1" Width="50174"><CELLMARGIN Bottom="0" Left="0" Right="0" Top="0"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="62"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="78" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="1666" Protect="false" RowAddr="2" RowSpan="1" Width="37752"><CELLMARGIN Bottom="283" Left="283" Right="283" Top="283"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="6" Style="0"><TEXT CharShape="42"><CHAR>■ 배변관리의 중요성</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="78" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="true" Header="false" Height="18047" Protect="false" RowAddr="2