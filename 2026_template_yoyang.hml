" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2390" Protect="false" RowAddr="2" RowSpan="1" Width="40044"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="43" Style="0"><TEXT CharShape="2"><CHAR>기초수급권자</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="6" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2390" Protect="false" RowAddr="2" RowSpan="1" Width="9885"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="42" Style="0"><TEXT CharShape="2"><CHAR>0%</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="6" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="5960" Protect="false" RowAddr="3" RowSpan="1" Width="40044"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="43" Style="0"><TEXT CharShape="77"><CHAR>기타 의료수급권자</CHAR></TEXT></P><P ParaShape="43" Style="0"><TEXT CharShape="2"><CHAR>차상위 의료급여 건강보험 자격전환자 (희귀난치성, 만성질환자)</CHAR></TEXT></P><P ParaShape="43" Style="0"><TEXT CharShape="2"><CHAR>저소득층 </CHAR></TEXT><TEXT CharShape="108"><CHAR>(본인부담금 감경을 위한 소득․재산 등이 일정금액 이하인 자에 관한 고시 해당자)</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="6" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="5960" Protect="false" RowAddr="3" RowSpan="1" Width="9885"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="42" Style="0"><TEXT CharShape="2"><CHAR>6%</CHAR></TEXT></P><P ParaShape="42" Style="0"><TEXT CharShap