"TopAndBottom" ZOrder="1"><SIZE Height="71829" HeightRelTo="Absolute" Protect="false" Width="50460" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="0" HorzRelTo="Column" TreatAsChar="false" VertAlign="Top" VertOffset="-4821" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/></SHAPEOBJECT><INSIDEMARGIN Bottom="141" Left="510" Right="510" Top="141"/><ROW><CELL BorderFill="4" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2182" Protect="false" RowAddr="0" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="20" Style="21"><TEXT CharShape="8"><CHAR>표준근로계약서</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="6" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="0" Protect="false" RowAddr="1" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="20" Style="21"><TEXT CharShape="9"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="7" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2622" Protect="false" RowAddr="2" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="1" Style="0"><TEXT CharShape="10"><CHAR> #{센터명} </CHAR></TEXT><TEXT CharShape="11"><CHAR>(이하‘사업주(사업주의 위임을 받은 사용자 포함)’라 함)과 </CHAR></TEXT><TEXT CharShape="10"><CHAR> #{근로자} </CHAR></TEXT><TEXT CharShape="11"><CHAR>(이하‘근로자’라 함)은(는) 다음과 같이 근로계약을 체결하고 상호 성실히 이행할 것을 확인한다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="7" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="0" Protect="false" RowAddr="3" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="1" Style="0"><TEXT CharShape="12"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4087" Protect="false" RowAddr="4" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>1. 근로계약기간</CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>1) 계약기간은 #{계약시작일} 부터 ~ #{계약종료일} 까지       <MARKPENBEGIN Color="16777215"/> ※최초 근로개시일 : #{최초근로개시일}<MARKPENEND/></CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>2) 계약기간 종료 시 계약의 갱신이나 연장이 이루어지지 않을 경우 본 근로계약은 해지되는 것으로 본다. 다만 상호 합의가 있을 경우 동일한 조건으로 1년간 연장된 것으로 본다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="5" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="14"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4062" Protect="false" RowAddr="6" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>2. 근무장소</CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><CHAR>1) 사업주의 사업장 및 기타 사용자가 지정하는 장소(수급자의 집)으로 한다.</CHAR></TEXT></P><P ParaShape="25" Style="0"><TEXT CharShape="11"><CHAR>* 단, 업무상 필요한 경우 ‘사업주’가 ‘근로자’와 협의 하에 근무 장소를 변경할 수 있다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="7" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4270" Protect="false" RowAddr="8" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>3. 근무직종 및 업무내용 </CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>1) 직종 : #{체크_사복} 사회복지사 #{체크_시설장} 시설장</CHAR></TEXT></P><P ParaShape="26" Style="0"><TEXT CharShape="11"><CHAR>2) 업무내용 : 당사 운영규정에 삽입된 업무분장표 내 해당 직종의 업무 일체 </CHAR></TEXT><TEXT CharShape="16"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="9" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="12174" Protect="false" RowAddr="10" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>4. 근로시간 및 휴게시간</CHAR></TEXT></P><P ParaShape="50" Style="0"><TEXT CharShape="50"><CHAR> </CHAR></TEXT><TEXT CharShape="49"><CHAR>1) 근무형태, 근무시간, 휴게시간은 다음 각호와 같다.</CHAR></TEXT></P><P ParaShape="50" Style="0"><TEXT CharShape="49"><CHAR>  ① 근무형태 : #{체크_기간제}기간제 #{체크_정규직}정규직</CHAR></TEXT></P><P ParaShape="50" Style="0"><TEXT CharShape="49"><CHAR>  ② 근무시간 : </CHAR></TEXT><TEXT CharShape="49"><CHAR>09:00~18:00</CHAR></TEXT><TEXT CharShape="49"/></P><P ParaShape="50" Style="0"><TEXT CharShape="49"><CHAR>  ③ 휴게시간 : 12:00~13:00을 원칙으로 하나 근무일 안에서 유동적으로 협의가 가능하다.</CHAR></TEXT><TEXT CharShape="51"/></P><P ParaShape="51" Style="0"><TEXT CharShape="52"><CHAR> 2) 1주간의 근로시간은 휴게시간을 제외하고 40시간을 초과할 수 없다. 단, 당사자 간의 합의에 따라 1주 12시간을 한도로 근무시간을 연장할 수 있다.</CHAR></TEXT></P><P ParaShape="51" Style="0"><TEXT CharShape="52"><CHAR> 3) 사용자는 근로시간이 4시간인 경우에는 30분 이상, 8시간인 경우에는 1시간 이상의 휴게시간을 부여한다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="11" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="12702" Protect="false" RowAddr="12" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>5. 근무일 및 휴일</CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><CHAR>1) 근무일 : </CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><CHAR>2) 휴  일 : </CHAR></TEXT></P><P ParaShape="25" Style="0"><TEXT CharShape="11"><CHAR>① 주휴일 : 주휴일은 매주 (#{체크_토요일}토요일/#{체크_일요일}일요일)로 한다.</CHAR></TEXT></P><P ParaShape="25" Style="0"><TEXT CharShape="11"><CHAR>② 근로자의 날(5.1.)</CHAR></TEXT></P><P ParaShape="25" Style="0"><TEXT CharShape="11"><CHAR>③ 근로기준법 시행령 제30조제2항에서 정하고 있는 공휴일 및 대체공휴일</CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><CHAR>3) 주휴일의 대체가 가능하며 이 경우 사업주는 7일 이내의 근무일과 대체함을 24시간 전에 근로자에게 통보해야 한다.</CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><CHAR>4) 공휴일의 대체는 근로자 대표와 서면합의를 통해 사전에 정할 수 있다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="13" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="17641" Protect="false" RowAddr="14" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>6. 임금</CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><CHAR>1) 급여적용기간 : #{계약시작일} 부터 ~ #{계약종료일} 까지</CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><TABLE BorderFill="3" CellSpacing="0" ColCount="4" PageBreak="Cell" RepeatHeader="true" RowCount="4"><SHAPEOBJECT InstId="1392119629" Lock="false" NumberingType="Table" TextWrap="TopAndBottom" ZOrder="0"><SIZE Height="8436" HeightRelTo="Absolute" Protect="false" Width="47519" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="632" HorzRelTo="Column" TreatAsChar="false" VertAlign="Top" VertOffset="1409" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/></SHAPEOBJECT><INSIDEMARGIN Bottom="141" Left="510" Right="510" Top="141"/><ROW><CELL BorderFill="16" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2613" Protect="false" RowAddr="0" RowSpan="1" Width="12819"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"><CHAR>임금항목</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="16" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2613" Protect="false" RowAddr="0" RowSpan="1" Width="12820"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"><CHAR>산정시간(월)</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="16" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2613" Protect="false" RowAddr="0" RowSpan="1" Width="11947"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"><CHAR>금액</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="16" ColAddr="3" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2613" Protect="false" RowAddr="0" RowSpan="1" Width="9933"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"><CHAR>비고</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="3" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="1" RowSpan="1" Width="12819"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="48"><CHAR>통상임금</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="1" RowSpan="1" Width="12820"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"><CHAR>209시간</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="1" RowSpan="1" Width="11947"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"><CHAR>2,156,880원</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="3" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="1" RowSpan="1" Width="9933"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"><CHAR>주휴수당 포함</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="3" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="2" RowSpan="1" Width="12819"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="48"/></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="2" RowSpan="1" Width="12820"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"/></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="2" RowSpan="1" Width="11947"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"/></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="3" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1942" Protect="false" RowAddr="2" RowSpan="1" Width="9933"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="3" ColAddr="0" ColSpan="2" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1939" Protect="false" RowAddr="3" RowSpan="1" Width="25639"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="48"><CHAR>합    계</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1939" Protect="false" RowAddr="3" RowSpan="1" Width="11947"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"/></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="3" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="1939" Protect="false" RowAddr="3" RowSpan="1" Width="9933"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="45" Style="0"><TEXT CharShape="47"/></P></PARALIST></CELL></ROW></TABLE><CHAR>2) 급여항목 : 월급제</CHAR></TEXT></P><P ParaShape="52" Style="0"><TEXT CharShape="11"/></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>3) 연장, 야간, 휴일근로를 한 경우에는 해당 시간에 대해 근로기준법 제56조에 따라 가산수당을 지급한다.</CHAR></TEXT></P><P InstId="2796506105" ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>4) 임금지급일 : 급여는 매월 01일부터 말일까지 정산하여 익월 #{지급일}에 지급한다. 단, 퇴사자의 경우 마지막 근무일이 속한 월의 급여지급일에 지급한다. (휴일의 경우는 전일 지급)  <MARKPENBEGIN Color="16777215"/>※근로자  </CHAR></TEXT><TEXT CharShape="10"><CHAR>  #{근로자}    </CHAR></TEXT><TEXT CharShape="11"><CHAR>(서명)   <MARKPENEND/></CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="54"/></P><P ParaShape="23" Style="0"><TEXT CharShape="11"/></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><CHAR>5) 임금지급방법 : 계좌이체(등록된 본인의 예금계좌로 입금)로 지급한다.</CHAR></TEXT></P><P ParaShape="23" Style="0"><TEXT CharShape="11"><TABLE BorderFill="3" CellSpacing="0" ColCount="6" PageBreak="Cell" RepeatHeader="true" RowCount="1"><SHAPEOBJECT InstId="2117446792" Lock="false" NumberingType="Table" TextWrap="TopAndBottom" ZOrder="2"><SIZE Height="2031" HeightRelTo="Absolute" Protect="false" Width="46914" WidthRelTo="Absolute"/><POSITION AffectLSpacing="false" AllowOverlap="false" FlowWithText="true" HoldAnchorAndSO="false" HorzAlign="Left" HorzOffset="1359" HorzRelTo="Column" TreatAsChar="true" VertAlign="Top" VertOffset="876" VertRelTo="Para"/><OUTSIDEMARGIN Bottom="283" Left="283" Right="283" Top="283"/></SHAPEOBJECT><INSIDEMARGIN Bottom="141" Left="510" Right="510" Top="141"/><ROW><CELL BorderFill="3" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2031" Protect="false" RowAddr="0" RowSpan="1" Width="4140"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="11"><CHAR>은행명</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2031" Protect="false" RowAddr="0" RowSpan="1" Width="6970"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="11"><CHAR>#{은행명}</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2031" Protect="false" RowAddr="0" RowSpan="1" Width="4989"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="11"><CHAR>계좌번호</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="3" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2031" Protect="false" RowAddr="0" RowSpan="1" Width="15177"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="11"><CHAR>#{계좌번호}</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="4" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2031" Protect="false" RowAddr="0" RowSpan="1" Width="6121"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="11"><CHAR>예금주</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="5" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2031" Protect="false" RowAddr="0" RowSpan="1" Width="9517"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="11"><CHAR>#{근로자}</CHAR></TEXT></P></PARALIST></CELL></ROW></TABLE><CHAR/></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="15" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="8382" Protect="false" RowAddr="16" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>7. 연차유급휴가 </CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>1) 1년간 80% 이상 출근한 경우 15일의 유급휴가를 부여한다. 계속하여 근로한 기간이 1년 미만인 경우 또는 1년간 80% 미만 출근한 경우에는 1개월 개근 시 1일의 유급휴가를 부여한다. </CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>2) 사용자는 근로자가 청구한 시기에 휴가를 주어야 한다. 다만, 청구한 시기에 휴가를 주는 것이 시설 운영에 막대한 지장이 있는 경우에는 그 시기를 변경할 수 있다. </CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>3) 기타 사항은 근로기준법 및 취업규칙 등에서 정하는 바에 따른다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="17" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"><CHAR> </CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4062" Protect="false" RowAddr="18" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>8. 사회보험 적용 및 신고</CHAR></TEXT><TEXT CharShape="11"><CHAR>(해당란에 체크)</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="11"><CHAR> 사업주는 근로자에 대하여 관계법령에 따라 사회보험을 신고한다.</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="11"><CHAR>  #{체크_고용} <MARKPENBEGIN Color="16777215"/>고용보험     <MARKPENEND/>#{체크_산재}<MARKPENBEGIN Color="16777215"/> 산재보험     <MARKPENEND/>#{체크_국민}<MARKPENBEGIN Color="16777215"/> 국민연금     ■ 건강보험<MARKPENEND/></CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="19" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="8382" Protect="false" RowAddr="20" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>9. 퇴직급여</CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>1) 퇴직급여제도의 종류 : #{체크_DC}DC   #{체크_DB}DB    #{체크_퇴직금}퇴직금 제도</CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>2) 사업주는 계속근로기간이 1년 이상, 1주간 평균 15시간 이상 근무한 자가 퇴직하는 경우 그 지급 사유가 발생한 날로부터 14일 이내에 퇴직급여를 지급하여야 한다.</CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>3) 근로자가 퇴직금을 받을 권리는 3년간 보장된다.</CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>4) 퇴직금과 관련한 그 외 구체적인 사항은 근로자퇴직급여보장법이 정한 바에 따른다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="21" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2622" Protect="false" RowAddr="22" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>10. 근로계약 해지 및 해고의 제한</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="11"><CHAR> 단체협약, 취업규칙, 근로기준법 등 노동관계법령에 따른다. </CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="23" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2647" Protect="false" RowAddr="24" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>11 근로계약서 교부</CHAR></TEXT></P><P ParaShape="1" Style="0"><TEXT CharShape="11"><CHAR> 근로계약서 1부를 사업주와 근로자 각각 작성하여 보관하도록 한다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="882" Protect="false" RowAddr="25" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="15"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="8" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="6942" Protect="false" RowAddr="26" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="1" Style="0"><TEXT CharShape="13"><CHAR>12. 기타</CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>1) 이 계약서에 명시되지 않은 사항은 단체협약, 취업규칙, 근로기준법 등 노동관계법령에 따르며, 사업주는 근로자의 권리와 의무를 명확히 설명해야 한다.</CHAR></TEXT></P><P ParaShape="24" Style="0"><TEXT CharShape="11"><CHAR>2) 본 계약에도 불구하고 4주간을 평균하여 1주 동안 소정 근무시간이 15시간 미만인 근로자는 퇴직금, 휴가, 유급휴일 등을 적용하지 아니한다.</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="7" ColAddr="0" ColSpan="5" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="4274" Protect="false" RowAddr="27" RowSpan="1" Width="50460"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="17"><CHAR>근로계약일 : #{근로계약일}</CHAR></TEXT><TEXT CharShape="53"/></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="7" ColAddr="0" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="21528" Protect="false" RowAddr="28" RowSpan="9" Width="17001"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Top"><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P><P ParaShape="21" Style="0"><TEXT CharShape="18"/></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="1" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="9460" Protect="false" RowAddr="28" RowSpan="4" Width="2569"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="19"><CHAR>사</CHAR></TEXT></P><P ParaShape="21" Style="0"><TEXT CharShape="19"><CHAR>업</CHAR></TEXT></P><P ParaShape="21" Style="0"><TEXT CharShape="19"><CHAR>주</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2365" Protect="false" RowAddr="28" RowSpan="1" Width="7096"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="19"><CHAR>기관명</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="3" ColSpan="2" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2365" Protect="false" RowAddr="28" RowSpan="1" Width="23794"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="1" Style="0"><TEXT CharShape="11"><CHAR>#{센터명}</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="3" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2365" Protect="false" RowAddr="29" RowSpan="1" Width="7096"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="21" Style="0"><TEXT CharShape="19"><CHAR>주  소</CHAR></TEXT></P></PARALIST></CELL><CELL BorderFill="3" ColAddr="3" ColSpan="2" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2365" Protect="false" RowAddr="29" RowSpan="1" Width="23794"><CELLMARGIN Bottom="141" Left="510" Right="510" Top="141"/><PARALIST LineWrap="Break" LinkListID="0" LinkListIDNext="0" TextDirection="0" VertAlign="Center"><P ParaShape="1" Style="0"><TEXT CharShape="11"><CHAR>#{센터주소}</CHAR></TEXT></P></PARALIST></CELL></ROW><ROW><CELL BorderFill="3" ColAddr="2" ColSpan="1" Dirty="false" Editable="false" HasMargin="false" Header="false" Height="2365" Protect="false" RowAddr="30" RowSpan="1" Width="7096"><CELL